{
  "name": "gatekeeper-mcp",
  "version": "0.1.0",
  "description": "MCP policy-as-code guardrails for AI-assisted software development.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "gatekeeper-mcp": "./dist/cli.js",
    "gatekeeper-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run --fileParallelism=false --reporter=verbose",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "smoke": "node scripts/run-smoke-test.mjs",
    "smoke:cli": "npm run build && node scripts/run-cli-smoke-test.mjs",
    "benchmark": "npm run build && node scripts/benchmark.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build && npm run smoke && npm run smoke:cli"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "policy-as-code",
    "ai-governance",
    "secure-sdlc",
    "claude",
    "typescript"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
